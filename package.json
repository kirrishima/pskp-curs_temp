{
  "name": "jwt-express-backend",
  "version": "1.0.0",
  "description": "Express.js backend with JWT auth, token versioning, and QR code login",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:setup": "npx prisma generate && npx prisma db push",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^17.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.0",
    "nodemailer": "^6.9.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  }
}
