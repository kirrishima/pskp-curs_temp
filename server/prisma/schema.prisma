datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

// ── Enums ───────────────────────────────────────────────────────────────────

enum RoomStatus {
  ACTIVE
  MAINTENANCE
  CLOSED
}

enum ServicePriceType {
  PER_NIGHT
  ONE_TIME
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
}

enum CancellationSource {
  GUEST
  ADMIN
  HOTEL
  SYSTEM
}

enum RefundStatus {
  NONE
  FULL
  PARTIAL
  PENDING
  FAILED
  ACTION_REQUIRED
}

enum RoomServiceState {
  INCLUDED
  OPTIONAL_ON
  OPTIONAL_OFF
}

enum HoldStatus {
  ACTIVE
  CONVERTED
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

// ── Roles ───────────────────────────────────────────────────────────────────

model Role {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique // "user" | "manager" | "admin"
  users User[]
}

// ── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  tokenVersion  Int       @default(0)

  phone         String?
  birthDate     DateTime?
  gender        String?
  citizenship   String?
  displayName   String?

  roleId        String    @db.Uuid
  role          Role      @relation(fields: [roleId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens RefreshToken[]
  qrCodes       QRCode[]
  roomHolds     RoomHold[]
  bookings      Booking[]

  @@index([roleId])
}

// ── Email Verification Codes ────────────────────────────────────────────────

model EmailVerification {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model RefreshToken {
  id           String   @id @default(uuid()) @db.Uuid
  token        String   @unique
  tokenVersion Int
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model QRCode {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([code])
  @@index([userId])
}

// ── Hotels ──────────────────────────────────────────────────────────────────

model Hotel {
  hotelCode    String   @id @map("hotel_code")
  name         String
  description  String?
  tagline      String?
  aboutText    String?  @map("about_text")
  heroImageUrl String?  @map("hero_image_url")
  city         String?
  address      String?
  phone        String?
  email        String?
  stars        Int?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  createdAt    DateTime @default(now())

  rooms Room[]

  @@map("hotels")
}

// ── Rooms ───────────────────────────────────────────────────────────────────

model Room {
  roomNo      String     @id @map("room_no")
  hotelCode   String     @map("hotel_code")
  hotel       Hotel      @relation(fields: [hotelCode], references: [hotelCode])

  title       String
  description String?

  capacity    Int
  bedsCount   Int        @map("beds_count")
  floor       Int?
  area        Decimal?   @db.Decimal(10, 2)

  basePrice   Decimal    @map("base_price") @db.Decimal(12, 2)

  status      RoomStatus @default(ACTIVE)

  createdAt   DateTime   @default(now())

  images       RoomImage[]
  roomServices RoomService[]
  roomHolds    RoomHold[]
  bookings     Booking[]

  @@index([hotelCode])
  @@index([status])
  @@index([floor])
  @@index([basePrice])
  @@index([capacity])
  @@index([bedsCount])
  @@map("rooms")
}

// ── Room Images ─────────────────────────────────────────────────────────────

model RoomImage {
  imageId    Int      @id @default(autoincrement()) @map("image_id")
  roomNo     String   @map("room_no")
  room       Room     @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)

  imageUrl   String   @map("image_url")
  isMain     Boolean  @default(false) @map("is_main")

  uploadedAt DateTime @default(now()) @map("uploaded_at")

  @@map("room_images")
}

// ── Services ────────────────────────────────────────────────────────────────

model Service {
  serviceCode  String           @id @map("service_code")
  title        String
  description  String?
  basePrice    Decimal          @default(0) @map("base_price") @db.Decimal(12, 2)
  priceType    ServicePriceType @map("price_type")
  icon         String?
  iconUrl      String?          @map("icon_url")
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now())

  roomServices    RoomService[]
  bookingServices BookingService[]

  @@map("services")
}

// ── Room ↔ Service (available amenities per room) ───────────────────────────

model RoomService {
  roomNo       String           @map("room_no")
  serviceCode  String           @map("service_code")

  room         Room             @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  service      Service          @relation(fields: [serviceCode], references: [serviceCode], onDelete: Cascade)

  defaultState RoomServiceState @map("default_state")

  @@id([roomNo, serviceCode])
  @@map("room_services")
}

// ── Room Holds (temporary reservation locks) ────────────────────────────────

model RoomHold {
  holdId    String     @id @default(uuid()) @map("hold_id") @db.Uuid
  roomNo    String     @map("room_no")
  userId    String     @map("user_id") @db.Uuid

  room      Room       @relation(fields: [roomNo], references: [roomNo])
  user      User       @relation(fields: [userId], references: [id])

  startDate DateTime   @map("start_date") @db.Date
  endDate   DateTime   @map("end_date")   @db.Date

  expiresAt DateTime   @map("expires_at")

  status    HoldStatus @default(ACTIVE)

  createdAt DateTime   @default(now())

  booking   Booking?

  @@index([roomNo, status])
  @@index([userId])
  @@index([expiresAt])
  @@map("room_holds")
}

// ── Bookings ────────────────────────────────────────────────────────────────

model Booking {
  bookingId   String        @id @default(uuid()) @map("booking_id") @db.Uuid
  holdId      String        @unique @map("hold_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  roomNo      String        @map("room_no")

  hold        RoomHold      @relation(fields: [holdId], references: [holdId])
  user        User          @relation(fields: [userId], references: [id])
  room        Room          @relation(fields: [roomNo], references: [roomNo])

  startDate   DateTime      @map("start_date") @db.Date
  endDate     DateTime      @map("end_date")   @db.Date

  status      BookingStatus @default(PENDING)

  totalAmount Decimal       @map("total_amount") @db.Decimal(12, 2)

  createdAt   DateTime      @default(now())
  notes       String?

  // ── Cancellation tracking ───────────────────────────────────────────────
  cancelledAt        DateTime?           @map("cancelled_at")
  cancelledByUserId  String?             @map("cancelled_by_user_id") @db.Uuid
  cancellationSource CancellationSource? @map("cancellation_source")
  cancellationReason String?             @map("cancellation_reason")
  penaltyAmount      Decimal?            @map("penalty_amount") @db.Decimal(12, 2)
  refundStatus       RefundStatus        @default(NONE) @map("refund_status")

  payment         Payment?
  bookingServices BookingService[]

  @@index([userId])
  @@index([roomNo])
  @@index([status])
  @@index([roomNo, startDate, endDate])
  @@map("bookings")
}

// ── Booking Services (snapshot of services included in a booking) ────────────

model BookingService {
  bookingId     String           @map("booking_id") @db.Uuid
  serviceCode   String           @map("service_code")

  booking       Booking          @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)
  service       Service          @relation(fields: [serviceCode], references: [serviceCode])

  sourceState   RoomServiceState @map("source_state")
  priceSnapshot Decimal          @map("price_snapshot") @db.Decimal(12, 2)

  @@id([bookingId, serviceCode])
  @@map("booking_services")
}

// ── Payments ────────────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  stripePaymentIntentId String        @unique @map("stripe_payment_intent_id")
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  bookingId             String        @unique @map("booking_id") @db.Uuid
  booking               Booking       @relation(fields: [bookingId], references: [bookingId])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // ── Stripe refund audit trail ───────────────────────────────────────────
  stripeChargeId      String?   @map("stripe_charge_id")
  stripeRefundId      String?   @unique @map("stripe_refund_id")
  stripeRefundStatus  String?   @map("stripe_refund_status")
  refundAmount        Decimal?  @map("refund_amount") @db.Decimal(12, 2)

  @@index([stripePaymentIntentId])
  @@index([status])
  @@map("payments")
}

// ── Webhook Events (idempotency log) ────────────────────────────────────────

model WebhookEvent {
  id            String   @id @default(uuid()) @db.Uuid
  stripeEventId String   @unique @map("stripe_event_id")
  type          String
  processedAt   DateTime @default(now())

  @@index([stripeEventId])
  @@map("webhook_events")
}
